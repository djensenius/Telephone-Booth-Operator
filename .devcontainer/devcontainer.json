{
  "name": "Telephone-Booth-Operator",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu26.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers-extra/features/mise:1": {},
    "ghcr.io/devcontainers-extra/features/npm-package:1": {
      "package": "vite-plus",
      "version": "0.1.22"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24.16.0",
      "pnpmVersion": "9.15.0"
    }
  },
  "postCreateCommand": "mise trust && mise install --jobs=1 && mise exec -- just setup",
  "forwardPorts": [
    5173,
    8787,
    5432,
    10000
  ],
  "portsAttributes": {
    "5173": {
      "label": "Operator web"
    },
    "8787": {
      "label": "Operator API"
    },
    "5432": {
      "label": "Postgres"
    },
    "10000": {
      "label": "Azurite blob storage"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "DavidAnson.vscode-markdownlint",
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "vitest.explorer"
      ]
    }
  }
}
