// Telephone-Booth-Operator Prisma schema.
// Datasource: Postgres. ORM: Prisma. Migrations live in prisma/migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  uploading
  received
  pending
  approved
  rejected
}

enum BoothState {
  idle
  dialTone
  dialing
  playingQuestion
  beep
  recording
  uploading
  playingMessage
  playingInstructions
  error
}

enum TranscriptionStatus {
  pending
  succeeded
  failed
}

enum ModerationRecommendation {
  approve
  review
  reject
}

model Question {
  id        String    @id @default(uuid()) @db.Uuid
  prompt    String    @unique
  audioId   String    @unique @db.Uuid
  audio     File      @relation(fields: [audioId], references: [id])
  createdAt DateTime  @default(now())
  retiredAt DateTime?
  messages  Message[]
}

model Message {
  id             String          @id @default(uuid()) @db.Uuid
  status         MessageStatus   @default(pending)
  notes          String?
  questionId     String?         @db.Uuid
  question       Question?       @relation(fields: [questionId], references: [id])
  audioId        String          @unique @db.Uuid
  audio          File            @relation(fields: [audioId], references: [id])
  createdAt      DateTime        @default(now())
  receivedAt     DateTime?
  decidedAt      DateTime?
  decidedById    String?
  decidedBy      OperatorUser?   @relation(fields: [decidedById], references: [id])
  transcriptions Transcription[]
  moderations    Moderation[]

  @@index([status, createdAt])
}

model File {
  id            String    @id @default(uuid()) @db.Uuid
  blobContainer String
  blobKey       String    @unique
  sha256        String    @unique
  sizeBytes     Int
  durationMs    Int?
  contentType   String
  createdAt     DateTime  @default(now())
  question      Question?
  message       Message?
}

model BoothStatusSnapshot {
  id                Int        @id @default(autoincrement())
  state             BoothState
  currentQuestionId String?    @db.Uuid
  currentMessageId  String?    @db.Uuid
  lastError         String?
  updatedAt         DateTime   @default(now())

  @@index([updatedAt])
}

// Persistent log of every observable event emitted by a booth (pickup,
// hangup, digit dialed, state transition, recording start/stop, upload
// lifecycle, errors, operator HTTP calls, audio device changes, …).
//
// Booth-supplied `eventId` plus `boothId` form a unique key so the
// `POST /v1/events` bulk endpoint is fully idempotent across retries.
// `recordingId` is a plain string (NOT @db.Uuid) because the booth side
// generates string ids like `recording-{monotonic_ns}`.
model BoothEvent {
  id          String       @id @default(cuid())
  eventId     String
  boothId     String
  bootId      String
  type        String
  occurredAt  DateTime
  receivedAt  DateTime     @default(now())
  sessionId   String?
  recordingId String?
  payload     Json
  session     CallSession? @relation(fields: [sessionId], references: [id])

  @@unique([boothId, eventId])
  @@index([occurredAt])
  @@index([boothId, occurredAt])
  @@index([type, occurredAt])
  @@index([sessionId])
  @@index([boothId, receivedAt, id])
}

// Derived from BoothEvent.call_started / call_ended pairs. The booth
// generates `id` as a UUIDv4 on pickup so the operator can group events
// into a session without joining on time windows.
model CallSession {
  id           String       @id
  boothId      String
  bootId       String
  startedAt    DateTime
  endedAt      DateTime?
  digitsDialed String?
  outcome      String?
  recordingId  String?
  durationMs   Int?
  events       BoothEvent[]

  @@index([boothId, startedAt])
  @@index([outcome])
}

// Operator humans authenticated via OIDC (Authentik by default).
// Row is created lazily on first successful login.
model OperatorUser {
  id                      String            @id // Historical internal ID; currently mirrors OIDC `sub`.
  oidcSub                 String            @unique
  email                   String            @unique
  name                    String
  groups                  Json? // raw groups claim at last login
  picture                 String?
  firstSeenAt             DateTime          @default(now())
  lastSeenAt              DateTime          @default(now())
  lastLoginAt             DateTime?
  apiTokens               ApiToken[]
  decisions               Message[]
  sessions                OperatorSession[]
  requestedTranscriptions Transcription[]   @relation("TranscriptionRequester")
  requestedModerations    Moderation[]      @relation("ModerationRequester")
}

model OperatorSession {
  id           String       @id
  userId       String
  user         OperatorUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  idToken      String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  lastSeenAt   DateTime     @default(now())
  ip           String?
  userAgent    String?

  @@index([userId])
  @@index([expiresAt])
}

// Static API tokens issued to phone-side clients.
// `tokenHash` is Argon2id; plaintext is shown to the operator exactly once.
model ApiToken {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  lookupId        String       @unique
  tokenHash       String
  last4           String
  createdByUserId String
  createdBy       OperatorUser @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime     @default(now())
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  revokedAt       DateTime?

  @@index([lookupId])
  @@index([revokedAt, expiresAt])
  @@index([createdByUserId, createdAt])
}

// AI transcription attempts. Each re-run inserts a new row (never overwrites
// a previous attempt) so the operator UI can show full history per message.
// Individual rows are updated in-place through their lifecycle:
// pending → succeeded | failed. `provider` and `model` are free-form strings
// so adding new providers does not require a migration. Current values are
// "openai", "mac_app", and "disabled".
model Transcription {
  id            String              @id @default(uuid()) @db.Uuid
  messageId     String              @db.Uuid
  message       Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  provider      String
  model         String?
  status        TranscriptionStatus @default(pending)
  text          String?
  language      String?
  durationMs    Int?
  latencyMs     Int?
  error         String?
  requestedById String?
  requestedBy   OperatorUser?       @relation("TranscriptionRequester", fields: [requestedById], references: [id])
  createdAt     DateTime            @default(now())
  completedAt   DateTime?
  moderations   Moderation[]

  @@index([messageId, createdAt])
  @@index([status, createdAt])
}

// AI moderation attempts. Linked to the `Transcription` row whose text was
// moderated so we can correlate. We reuse `TranscriptionStatus` for the row
// lifecycle (pending → succeeded | failed).
model Moderation {
  id              String                    @id @default(uuid()) @db.Uuid
  messageId       String                    @db.Uuid
  message         Message                   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transcriptionId String?                   @db.Uuid
  transcription   Transcription?            @relation(fields: [transcriptionId], references: [id], onDelete: SetNull)
  provider        String
  model           String?
  status          TranscriptionStatus       @default(pending)
  flagged         Boolean?
  recommendation  ModerationRecommendation?
  maxScore        Float?
  categories      Json?
  reasonSummary   String?
  latencyMs       Int?
  error           String?
  requestedById   String?
  requestedBy     OperatorUser?             @relation("ModerationRequester", fields: [requestedById], references: [id])
  createdAt       DateTime                  @default(now())
  completedAt     DateTime?

  @@index([messageId, createdAt])
  @@index([recommendation, createdAt])
}
