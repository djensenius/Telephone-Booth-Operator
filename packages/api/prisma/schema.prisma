// Telephone-Booth-Operator Prisma schema.
// Datasource: Postgres. ORM: Prisma. Migrations live in prisma/migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  uploading
  received
  pending
  approved
  rejected
}

enum BoothState {
  idle
  dialTone
  dialing
  playingQuestion
  beep
  recording
  uploading
  playingMessage
  playingInstructions
  error
}

model Question {
  id        String   @id @default(uuid()) @db.Uuid
  prompt    String   @unique
  audioId   String   @unique @db.Uuid
  audio     File     @relation(fields: [audioId], references: [id])
  createdAt DateTime @default(now())
  retiredAt DateTime?
  messages  Message[]
}

model Message {
  id          String        @id @default(uuid()) @db.Uuid
  status      MessageStatus @default(pending)
  notes       String?
  questionId  String?       @db.Uuid
  question    Question?     @relation(fields: [questionId], references: [id])
  audioId     String        @unique @db.Uuid
  audio       File          @relation(fields: [audioId], references: [id])
  createdAt   DateTime      @default(now())
  receivedAt  DateTime?
  decidedAt   DateTime?
  decidedById String?
  decidedBy   OperatorUser? @relation(fields: [decidedById], references: [id])

  @@index([status, createdAt])
}

model File {
  id            String   @id @default(uuid()) @db.Uuid
  blobContainer String
  blobKey       String   @unique
  sha256        String   @unique
  sizeBytes     Int
  durationMs    Int?
  contentType   String
  createdAt     DateTime @default(now())
  question      Question?
  message       Message?
}

model BoothStatusSnapshot {
  id                Int        @id @default(autoincrement())
  state             BoothState
  currentQuestionId String?    @db.Uuid
  currentMessageId  String?    @db.Uuid
  lastError         String?
  updatedAt         DateTime   @default(now())

  @@index([updatedAt])
}

// Operator humans authenticated via OIDC (Authentik by default).
// Row is created lazily on first successful login.
model OperatorUser {
  id          String            @id // Historical internal ID; currently mirrors OIDC `sub`.
  oidcSub     String            @unique
  email       String            @unique
  name        String
  groups      Json? // raw groups claim at last login
  picture     String?
  firstSeenAt DateTime          @default(now())
  lastSeenAt  DateTime          @default(now())
  lastLoginAt DateTime?
  apiTokens   ApiToken[]
  decisions   Message[]
  sessions    OperatorSession[]
}

model OperatorSession {
  id           String       @id
  userId       String
  user         OperatorUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  idToken      String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  lastSeenAt   DateTime     @default(now())
  ip           String?
  userAgent    String?

  @@index([userId])
  @@index([expiresAt])
}

// Static API tokens issued to phone-side clients.
// `tokenHash` is Argon2id; plaintext is shown to the operator exactly once.
model ApiToken {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  lookupId        String       @unique
  tokenHash       String
  last4           String
  createdByUserId String
  createdBy       OperatorUser @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime     @default(now())
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  revokedAt       DateTime?

  @@index([lookupId])
  @@index([revokedAt, expiresAt])
  @@index([createdByUserId, createdAt])
}
