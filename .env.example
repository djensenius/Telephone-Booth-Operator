# Telephone-Booth-Operator — example environment.
# Copy to .env and fill in real values.

# ─── HTTP ────────────────────────────────────────────────────────────────
API_PORT=8787
WEB_PORT=5173
PUBLIC_API_URL=http://localhost:8787
PUBLIC_WEB_URL=http://localhost:5173

# ─── Database (Postgres) ─────────────────────────────────────────────────
# Docker compose provides a postgres service at db:5432.
DATABASE_URL=postgres://booth:booth@localhost:5432/telephone_booth

# ─── Azure Blob Storage ──────────────────────────────────────────────────
# Local dev uses Azurite via docker-compose. The connection string below is
# Azurite's well-known default; do NOT use it in production.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
AZURE_BLOB_CONTAINER=booth-recordings
# Production override (uncomment in real .env):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_BLOB_CONTAINER=booth-recordings
# Optional: minutes a SAS upload URL stays valid.
AZURE_SAS_TTL_MINUTES=15

# Browser origins allowed to send credentials. Comma-separated for multi-host deploys.
WEB_ORIGIN=http://localhost:5173
# Comma-separated reverse proxy IPs/CIDRs whose X-Forwarded-* headers are trusted.
TRUSTED_PROXIES=

# ─── Operator session ────────────────────────────────────────────────────
# Cookie HMAC key. Generate: `openssl rand -hex 32`
SESSION_SECRET=replace-me-with-64-char-random-hex
# AES-256-GCM key for encrypted refresh tokens. Generate: `openssl rand -base64 32`
SESSION_ENCRYPTION_KEY=replace-me-with-32-byte-base64
# Local browser session lifetime. Access tokens may be shorter and are refreshed.
SESSION_TTL_SECONDS=43200
# Local development only; never enable in production.
AUTH_DISABLED=false

# ─── OIDC: Authentik (default provider) ──────────────────────────────────
OIDC_PROVIDER_NAME=Authentik
AUTHENTIK_ISSUER=https://authentik.example.com/application/o/telephone-booth-operator/
AUTHENTIK_CLIENT_ID=replace-me
AUTHENTIK_CLIENT_SECRET=replace-me
AUTHENTIK_REDIRECT_URI=http://localhost:8787/v1/auth/callback
AUTHENTIK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
AUTHENTIK_ALLOWED_GROUPS=telephone-booth-operators

# ─── OIDC: generic aliases (use these instead of AUTHENTIK_* if you wish) ─
# Any non-empty OIDC_* var overrides its AUTHENTIK_* counterpart.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
# OIDC_POST_LOGOUT_REDIRECT_URI=
# OIDC_SCOPES=openid email profile offline_access
# OIDC_ALLOWED_GROUPS=telephone-booth-operators
# OIDC_ALLOWED_EMAILS=
# Comma-separated Authentik client_ids of native/mobile apps that authenticate
# via PKCE against the same provider. Their access-token `aud` claims are
# additionally accepted by the operator bearer-token middleware. The primary
# OIDC_CLIENT_ID above is always accepted.
# OIDC_MOBILE_AUDIENCES=telephone-booth-operator-mobile

# ─── Phone-client API token defaults ─────────────────────────────────────
# Bytes of entropy used when generating new tokens (32 = 256 bits).
API_TOKEN_BYTES=32

# ─── Tracing / logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ─── AI: transcription + moderation ──────────────────────────────────────
# Each provider is independently selectable. Default `disabled` keeps the
# pipeline a no-op in dev. See docs/transcription-providers.md.
# Transcription provider: openai | mac_app | disabled
TRANSCRIPTION_PROVIDER=disabled
TRANSCRIPTION_OPENAI_MODEL=whisper-1
TRANSCRIPTION_MAC_APP_URL=
TRANSCRIPTION_MAC_APP_TOKEN=

# Moderation provider: openai | mac_app | disabled
MODERATION_PROVIDER=disabled
MODERATION_OPENAI_MODEL=omni-moderation-latest
MODERATION_MAC_APP_URL=
MODERATION_MAC_APP_TOKEN=

# Shared OpenAI credentials (used for both endpoints above when OPENAI is
# selected). Never commit real keys.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Auto-decision based on moderation result.
# always_pending — operator always decides (default; safest).
# auto_reject    — auto-reject above AUTO_REJECT_THRESHOLD, else pending.
# auto_both      — also auto-approve clean recordings below AUTO_APPROVE_THRESHOLD.
AUTO_DECISION_MODE=always_pending
AUTO_REJECT_THRESHOLD=0.85
AUTO_APPROVE_THRESHOLD=0.15

# Recovery sweeper cadence (seconds). The sweeper picks up `received`
# messages that never got transcribed (e.g. after a crash).
AI_SWEEPER_INTERVAL_SECONDS=60
